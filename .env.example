# =============================================================================
# Call of Duty 1 (v1.1) Dedicated Server — Environment Variables
# https://github.com/mmBesar/cod-container
#
# Copy this file to .env and edit to your needs:
#   cp .env.example .env
#
# .env is loaded automatically by docker compose.
# Never commit .env to git — it contains your passwords.
# =============================================================================

# --- Host user (run server as your own user, not root) -----------------------
UID=1000
GID=1000

# --- Server identity ---------------------------------------------------------
SERVER_HOSTNAME=CoD1 Docker Server
SERVER_PASSWORD=
RCON_PASSWORD=changeme
MOTD=Welcome to CoD1 Docker Server!

# --- Network -----------------------------------------------------------------
SERVER_PORT=28960
SERVER_IP=           # Leave empty to auto-detect container IP

# --- Gameplay ----------------------------------------------------------------
# Gametypes: dm (Deathmatch) | tdm (Team DM) | sd (Search & Destroy)
#            re (Retrieval)  | bel (Behind Enemy Lines)
GAMETYPE=tdm
MAX_CLIENTS=16
SV_PURE=0
FRIENDLY_FIRE=0
SCORE_LIMIT=100
TIME_LIMIT=30
ROUND_LIMIT=0
ALLOW_VOTE=0

# --- Maps --------------------------------------------------------------------
START_MAP=mp_harbor

# Space-separated map rotation list.
# Leave empty to loop START_MAP only.
# Example: MAP_ROTATION=mp_harbor mp_dawnville mp_carentan mp_brecourt mp_powcamp
MAP_ROTATION=

# --- CoDExtended -------------------------------------------------------------
X_AUTHORIZE=0            # 0=cracked (no CD key check)  1=require valid CD key
X_DEADCHAT=0             # 0=dead players chat hidden from alive  1=visible
X_NOPBOTS=1              # 1=fix bot movement glitches
X_SPECTATOR_NOCLIP=0     # 1=allow spectators to fly through walls
SV_FAST_DOWNLOAD=1       # 1=enable HTTP fast download redirect

# --- Masterserver ------------------------------------------------------------
SV_MASTER=master.cod.pm

# --- Bots (MeatBot RC2) ------------------------------------------------------
# WARNING: MeatBot was designed for listen servers. Dedicated server use
# is experimental and requires addbot commands after server start.
# See README for details.
BOTS_ENABLED=false
BOTS_COUNT=4
BOTS_TEAM=autoassign     # allies | axis | autoassign
BOTS_DIFFICULTY=5        # 0 (easiest) to 10 (hardest)

# --- Misc --------------------------------------------------------------------
SV_FPS=20
EXTRA_ARGS=              # Raw args appended to server launch command
